# ==============================================================================
# StableBonds - Configuration Environment Variables Template
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. SMART CONTRACTS CONFIGURATION (Use in /contracts/.env)
# ------------------------------------------------------------------------------
# [Required] Arc Testnet RPC URL
ARC_TESTNET_RPC_URL=https://rpc.testnet.arc.network

# [Required] Deployer Wallet Private Key (Do not include 0x prefix, must be funded with Testnet USDC for gas)
PRIVATE_KEY=your_private_key_here


# ------------------------------------------------------------------------------
# 2. NEXT.JS FRONTEND & RELAYER CONFIGURATION (Use in /app/.env.local)
# ------------------------------------------------------------------------------
# [Required] Circle Client SDK Credentials (from Circle Developer Console)
NEXT_PUBLIC_CIRCLE_CLIENT_KEY=TEST_CLIENT_KEY_0123456789abcdef
NEXT_PUBLIC_CIRCLE_CLIENT_URL=https://modular-sdk.circle.com/v1/rpc/w3s/buidl

# [Required] Arc Testnet RPC URL for Server-Side API Routes
ARC_TESTNET_RPC_URL=https://rpc.testnet.arc.network

# [Required for Basic Relayer] Private Key for local server-side signing in /api/cron/settle
PRIVATE_KEY=your_private_key_here

# [Required for Enterprise Relayer] Circle WaaS Credentials (for MPC signing in /api/cron/settle-enterprise)
# Obtain from Circle Developer Console
CIRCLE_API_KEY=your_circle_api_key_here
ENTITY_SECRET_CIPHERTEXT=your_entity_secret_ciphertext_here
CIRCLE_WALLET_ID=your_circle_wallet_id_here

# [Optional] Reown / WalletConnect Cloud Project ID (unlocked fallback provided if blank)
NEXT_PUBLIC_REOWN_PROJECT_ID=your_reown_project_id_here

